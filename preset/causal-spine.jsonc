{
  // causal-conductor preset for oh-my-opencode-slim.
  // Merge this into ~/.config/opencode/oh-my-opencode-slim.jsonc and set
  //   "preset": "causal-spine"
  // Requires: the causal-powers skills plugin (skill names below resolve from it).
  //
  // NOTE: this is a SOFT-CONTRACT distribution. The orchestrator is prompted to
  // draft a <spine_contract> and wait for approval, but stock oh-my-opencode-slim
  // does NOT structurally enforce a write-gate. Do not rely on it to physically
  // block writes before approval.
  //
  // Models below are the recommended defaults (flagship orchestrator + a strong
  // independent reviewer). Swap them for the providers you have authenticated.
  "preset": "causal-spine",
  "presets": {
    "causal-spine": {
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "mcps": [],
        "skills": [
          "question-framing",
          "using-causal-powers",
          "causal-identification",
          "structural-estimation",
          "predictive-modeling",
          "pre-analysis-plan",
          "executing-analysis-plans"
        ]
      },
      "oracle": {
        "model": "deepseek/deepseek-v4-pro",
        "variant": "max",
        "mcps": [],
        "skills": [
          "analysis-checkpoints",
          "analysis-craft",
          "analysis-review",
          "causal-identification",
          "data-contracts",
          "data-preparation",
          "executing-analysis-plans",
          "pre-analysis-plan",
          "predictive-modeling",
          "project-organization",
          "question-framing",
          "result-verification",
          "structural-estimation",
          "using-causal-powers",
          "wrong-number-debugging"
        ]
      },
      "fixer": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "mcps": [],
        "skills": [
          "data-preparation",
          "executing-analysis-plans",
          "predictive-modeling",
          "causal-identification",
          "structural-estimation"
        ]
      },
      "explorer": {
        "model": "deepseek/deepseek-v4-flash",
        "variant": "max",
        "mcps": ["codegraph"],
        "skills": []
      },
      "librarian": {
        "model": "deepseek/deepseek-v4-flash",
        "variant": "max",
        "mcps": ["exawebsearch", "context7", "gh_grep", "codegraph"],
        "skills": []
      }
    }
  },
  "disabled_agents": ["observer", "designer"]
}
