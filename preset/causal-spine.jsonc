{
  // causal-conductor preset for oh-my-opencode-slim.
  // Merge this into ~/.config/opencode/oh-my-opencode-slim.jsonc and set
  //   "preset": "causal-spine"
  // Requires: the causal-powers skills plugin (skill names below resolve from it).
  //
  // NOTE: the contract is ENFORCED when you also install the bundled spine plugin
  // (plugin/ — register its path in opencode.jsonc). Without that plugin this is a
  // SOFT contract: the orchestrator is prompted to draft a <spine_contract> and
  // wait, but nothing structurally blocks writes before approval.
  //
  // Models below are the recommended defaults (flagship orchestrator + a strong
  // independent reviewer). Swap them for the providers you have authenticated.
  "preset": "causal-spine",
  "presets": {
    "causal-spine": {
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "mcps": [],
        // Full causal-powers set: the orchestrator is equipped to do any
        // analysis step itself so it never hits a deny wall and can handle
        // entangled work inline. Delegation stays the DEFAULT (see the
        // orchestrator append) — having a skill is not a reason to do the work
        // here when a clean brief to @fixer/@oracle would do.
        "skills": [
          "question-framing",
          "using-causal-powers",
          "causal-identification",
          "structural-estimation",
          "predictive-modeling",
          "pre-analysis-plan",
          "executing-analysis-plans",
          "descriptive-evidence",
          "analysis-checkpoints",
          "result-verification",
          "analysis-review",
          "data-preparation",
          "data-contracts",
          "analysis-craft",
          "wrong-number-debugging",
          "project-organization"
        ]
      },
      "oracle": {
        "model": "deepseek/deepseek-v4-pro",
        "variant": "max",
        "mcps": [],
        "skills": [
          "analysis-checkpoints",
          "analysis-craft",
          "analysis-review",
          "causal-identification",
          "data-contracts",
          "data-preparation",
          "descriptive-evidence",
          "executing-analysis-plans",
          "pre-analysis-plan",
          "predictive-modeling",
          "project-organization",
          "question-framing",
          "result-verification",
          "structural-estimation",
          "using-causal-powers",
          "wrong-number-debugging"
        ]
      },
      "fixer": {
        "model": "openai/gpt-5.5",
        "variant": "xhigh",
        "mcps": [],
        // Execution lane — same model as the orchestrator, so it must carry the
        // execution discipline to match its depth on a delegated task. Added
        // data-contracts (join/cardinality/silent-failure guards), analysis-craft
        // (surgical minimal code), and wrong-number-debugging so a delegated step
        // is not shallower than one done inline.
        "skills": [
          "data-preparation",
          "data-contracts",
          "analysis-craft",
          "wrong-number-debugging",
          "descriptive-evidence",
          "executing-analysis-plans",
          "predictive-modeling",
          "causal-identification",
          "structural-estimation",
          "just-enough"
        ]
      },
      "explorer": {
        "model": "deepseek/deepseek-v4-flash",
        "variant": "max",
        "mcps": ["codegraph"],
        "skills": []
      },
      "librarian": {
        "model": "deepseek/deepseek-v4-flash",
        "variant": "max",
        "mcps": ["exawebsearch", "context7", "gh_grep", "codegraph"],
        "skills": []
      }
    }
  },
  "disabled_agents": ["observer", "designer"]
}
